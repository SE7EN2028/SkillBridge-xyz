// SkillBridge Prisma schema
// Domain: Users (Worker/Employer/Admin), WorkerProfile, Skills, Jobs, Applications, Reviews, RefreshTokens

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  WORKER
  EMPLOYER
  ADMIN
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          Role
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  workerProfile WorkerProfile?
  jobsPosted    Job[]          @relation("EmployerJobs")
  reviewsGiven  Review[]       @relation("ReviewerReviews")
  refreshTokens RefreshToken[]

  @@index([role])
  @@index([email])
}

model WorkerProfile {
  id            String        @id @default(uuid())
  userId        String        @unique
  bio           String?
  city          String
  hourlyRate    Float
  isAvailable   Boolean       @default(true)
  isVerified    Boolean       @default(false)
  averageRating Float         @default(0)
  reviewCount   Int           @default(0)
  photoUrl      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills        Skill[]
  applications  Application[]
  reviews       Review[]      @relation("WorkerReviews")

  @@index([city])
  @@index([isVerified])
  @@index([isAvailable])
  @@index([averageRating])
}

model Skill {
  id              String        @id @default(uuid())
  workerProfileId String
  skillName       String
  yearsExp        Int
  certificateUrl  String?
  createdAt       DateTime      @default(now())

  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@unique([workerProfileId, skillName])
  @@index([skillName])
}

model Job {
  id            String        @id @default(uuid())
  employerId    String
  title         String
  description   String?
  skillRequired String
  city          String
  budget        Float
  status        JobStatus     @default(OPEN)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  employer      User          @relation("EmployerJobs", fields: [employerId], references: [id], onDelete: Cascade)
  applications  Application[]

  @@index([employerId])
  @@index([skillRequired])
  @@index([city])
  @@index([status])
}

model Application {
  id              String            @id @default(uuid())
  jobId           String
  workerProfileId String
  status          ApplicationStatus @default(PENDING)
  coverNote       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  job             Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerProfile   WorkerProfile     @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  review          Review?

  @@unique([jobId, workerProfileId])
  @@index([status])
}

model Review {
  id              String        @id @default(uuid())
  applicationId   String        @unique
  workerProfileId String
  reviewerId      String
  rating          Int
  comment         String?
  createdAt       DateTime      @default(now())

  application     Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  workerProfile   WorkerProfile @relation("WorkerReviews", fields: [workerProfileId], references: [id], onDelete: Cascade)
  reviewer        User          @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([workerProfileId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
